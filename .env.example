# .env file for keeptrack-space

# Path to the settings TypeScript file
SETTINGS_PATH=public/settings/settingsOverride.js
FAVICON_PATH=public/img/favicons/favicon.ico
LOADING_SCREEN_CSS_PATH=public/css/loading-screen.css
STYLE_CSS_PATH=public/css/style.css
TEXT_LOGO_PATH=public/img/logo.png
PRIMARY_LOGO_PATH=public/img/logo-primary.png
SECONDARY_LOGO_PATH=public/img/logo-secondary.png
MODE=development
IS_PRO=false

# server addresses
# Recommended deployment: expose backend through same-origin reverse proxy
TIANXUN_SERVER_LOGIN=/api/login
TIANXUN_SERVER_SETTINGS=/api/settings

# Online User Manual URL
USER_MANUAL_URL=/manual

# ScAI Agent Frontend URL (independent deployment recommended)
# Using localhost here is safe: frontend code will normalize it to current hostname.
SCAI_AGENT_URL=http://localhost:5173/

# ADS-B / AIS embedded page URLs (supports ip:port or full URL)
SCAI_ADSB_URL=http://localhost:8502
SCAI_AIS_URL=http://localhost:8503
